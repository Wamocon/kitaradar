# =============================================================================
# Environment Variables — KitaRadar
# =============================================================================
# Copy this file to .env.local and fill in the values:
#   cp .env.example .env.local
#
# NEVER commit .env.local to version control!
# =============================================================================

# --- Next.js -----------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=KitaRadar

# --- Supabase ----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase Schema Selection:
#   Local dev:   kitaradar-dev
#   Test/Preview: kitaradar-test   (set in Vercel "Preview" environment)
#   Production:  kitaradar-prod    (set in Vercel "Production" environment)
NEXT_PUBLIC_SUPABASE_SCHEMA=kitaradar-dev

# --- OpenAI / MAX AI (self-hosted LiteLLM gateway) -------------------------
# Point these at your own MAX/LiteLLM instance. No token limits apply.
# The app injects enable_thinking:false automatically for qwen3 CoT models.
#
# Model routing:
#   DEFAULT    → General use, recommendations, cover letters
#   REASONING  → Highest quality (worth longer wait for premium features)
#   TOOLS      → Fast structured JSON extraction, ranking
#   VISION     → Image / OCR understanding
#   EMBEDDING  → Semantic search & similarity
#
# Typical response times (self-hosted, no token limit):
#   glm-4.7-flash  ~10s  | qwen3.6:35b ~15-29s | gemma4:31b ~31-38s
#   judge ~83s            | qwen3.5:122b ~92s
MAX_AI_BASE_URL=http://your-litellm-host:4000/v1
MAX_AI_API_KEY=your-litellm-api-key
MAX_AI_MODEL_DEFAULT=qwen3.6:35b
MAX_AI_MODEL_REASONING=judge
MAX_AI_MODEL_TOOLS=glm-4.7-flash
MAX_AI_MODEL_VISION=gemma4:31b
MAX_AI_MODEL_EMBEDDING=qwen3-embedding:8b

# Legacy OpenAI key (not used when MAX_AI_BASE_URL is set)
# OPENAI_API_KEY=sk-your-openai-api-key

# --- Stripe ------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price IDs (set these after creating products in Stripe Dashboard)
STRIPE_PRO_PRICE_ID=price_your-pro-price-id

