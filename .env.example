# =============================================================================
# Environment Variables — KitaRadar
# =============================================================================
# Copy this file to .env.local and fill in the values:
#   cp .env.example .env.local
#
# NEVER commit .env.local to version control!
# =============================================================================

# --- Next.js -----------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=KitaRadar

# --- Supabase ----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase Schema Selection:
#   Local dev:   kitaradar-dev
#   Test/Preview: kitaradar-test   (set in Vercel "Preview" environment)
#   Production:  kitaradar-prod    (set in Vercel "Production" environment)
NEXT_PUBLIC_SUPABASE_SCHEMA=kitaradar-dev

# --- OpenAI ------------------------------------------------------------------
# Used for AI search assistant and AI application generator (server-side only)
OPENAI_API_KEY=sk-your-openai-api-key

# --- Stripe ------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price IDs (set these after creating products in Stripe Dashboard)
STRIPE_PRO_PRICE_ID=price_your-pro-price-id

